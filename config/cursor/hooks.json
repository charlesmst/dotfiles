{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "command": "bash ~/.cursor/hooks/write-session-meta.sh"
      }
    ],
    "sessionEnd": [
      {
        "command": "bash ~/.cursor/hooks/clear-session-meta.sh"
      }
    ],
    "beforeSubmitPrompt": [
      {
        "command": "\"$HOME/.local/bin/agent-view\" event clear"
      },
      {
        "command": "AGENT=cursor bash ~/personal/dotfiles/tmux/agent-attention/auto-name.sh"
      },
      {
        "command": "AGENT=cursor bash ~/personal/dotfiles/tmux/agent-attention/sync-tmux-name.sh"
      }
    ],
    "stop": [
      {
        "command": "\"$HOME/.local/bin/agent-view\" event pending --agent cursor --unless-focused --message \"Turn finished — awaiting your input\""
      },
      {
        "command": "AGENT=cursor bash ~/personal/dotfiles/config/agent-shared/notify-if-unfocused.sh"
      },
      {
        "command": "AGENT=cursor bash ~/personal/dotfiles/tmux/agent-attention/sync-tmux-name.sh"
      }
    ]
  }
}
